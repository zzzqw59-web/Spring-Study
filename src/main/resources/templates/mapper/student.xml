<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.boot.example.mapper.StudentMapper">

    <resultMap id="studentResult" type="com.boot.example.domain.StudentDTO">
        <result column="no" property="no"></result>
        <result column="sd_num" property="studentNumber"></result>
        <result column="sd_name" property="studentName"></result>
        <result column="sd_id" property="studentId"></result>
        <result column="sd_passwd" property="studentPassword"></result>
        <result column="sd_birth" property="studentBirth"></result>
        <result column="sd_phone" property="studentPhone"></result>
        <result column="sd_address" property="studentAddress"></result>
        <result column="sd_email" property="studentEmail"></result>
        <result column="sd_date" property="regDate"></result>
    </resultMap>

    <select id="studentList" resultMap="studentResult">
        SELECT no, sd_num, sd_name, sd_id, sd_passwd, sd_birth, sd_phone, sd_address, sd_email, sd_date
        FROM student
    </select>

    <insert id="studentInsert" parameterType="com.boot.example.domain.StudentDTO" useGeneratedKeys="true" keyColumn="no" keyProperty="no">
        INSERT INTO student(sd_num, sd_name, sd_id, sd_passwd, sd_birth, sd_phone, sd_address, sd_email, sd_date)
        VALUES (#{studentNumber}, #{studentName}, #{studentId}, #{studentPassword}, #{studentBirth}, #{studentPhone}, #{studentAddress}, #{studentEmail}, #{regDate})
    </insert>

</mapper>